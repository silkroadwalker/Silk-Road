<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="480.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.silkroad.ui.EditAdController">
    <children>
        <Label alignment="CENTER" layoutX="220.0" layoutY="15.0" prefHeight="35.0" prefWidth="160.0" text="Edit Ad">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>
        <Button layoutX="25.0" layoutY="18.0" mnemonicParsing="false" onAction="#goBack" text="Back" />

        <TextField fx:id="titleField" layoutX="74.0" layoutY="65.0" prefHeight="27.0" prefWidth="455.0" promptText="Title" />
        <TextArea fx:id="descriptionField" layoutX="73.0" layoutY="100.0" prefHeight="90.0" prefWidth="455.0" promptText="Description" wrapText="true" />
        <TextField fx:id="priceField" layoutX="73.0" layoutY="200.0" prefHeight="27.0" prefWidth="455.0" promptText="Price" />
        <ComboBox fx:id="cityComboBox" layoutX="74.0" layoutY="237.0" prefHeight="27.0" prefWidth="455.0" promptText="City" />
        <ComboBox fx:id="categoryComboBox" layoutX="74.0" layoutY="274.0" prefHeight="27.0" prefWidth="455.0" promptText="Category" />

        <Label fx:id="statusLabel" layoutX="74.0" layoutY="320.0" prefWidth="455.0" styleClass="status-label" wrapText="true" />
        <Button fx:id="submitButton" layoutX="209.0" layoutY="360.0" mnemonicParsing="false" onAction="#handleSave" prefHeight="27.0" prefWidth="182.0" text="Save Changes" styleClass="primary-button" />
    </children>
</AnchorPane>
