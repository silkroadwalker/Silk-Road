<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.silkroad.ui.AdDetailsController" prefWidth="750" prefHeight="650">

    <top>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
            <Button text="Back" onAction="#goBack"/>
            <Label text="Ad Details" styleClass="page-title"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true">
            <VBox spacing="12">
                <padding><Insets top="10" right="20" bottom="20" left="20"/></padding>

                <HBox fx:id="imagesBox" spacing="8"/>

                <Label fx:id="titleLabel" wrapText="true">
                    <font><Font name="System Bold" size="22.0"/></font>
                </Label>
                <Label fx:id="priceLabel" styleClass="price-label"/>
                <Label fx:id="categoryCityLabel" styleClass="muted-label"/>
                <Label fx:id="statusValueLabel" styleClass="muted-label"/>
                <Label fx:id="rejectionReasonLabel" styleClass="error-label"/>

                <Separator/>

                <Label text="Description" styleClass="bold-label"/>
                <Label fx:id="descriptionLabel" wrapText="true"/>

                <Separator/>

                <Label text="Seller" styleClass="bold-label"/>
                <Label fx:id="sellerLabel"/>
                <Label fx:id="sellerRatingLabel"/>

                <Label fx:id="ownerNoteLabel" styleClass="muted-label"/>

                <HBox spacing="10">
                    <Button fx:id="favoriteButton" onAction="#handleToggleFavorite" text="Add to Favorites"/>
                    <Button fx:id="messageButton" onAction="#handleMessageSeller" text="Message Seller" styleClass="primary-button"/>
                    <Button fx:id="rateButton" onAction="#handleRateSeller" text="Rate Seller"/>
                </HBox>

                <Label fx:id="statusLabel" styleClass="status-label"/>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
