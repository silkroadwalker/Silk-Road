<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.silkroad.ui.AdDetailsController" prefWidth="750" prefHeight="650">

    <top>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
            <Button text="Back" onAction="#goBack"/>
            <Label text="Ad Details" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true">
            <VBox spacing="12">
                <padding><Insets top="10" right="20" bottom="20" left="20"/></padding>

                <HBox fx:id="imagesBox" spacing="8"/>

                <Label fx:id="titleLabel" wrapText="true">
                    <font><Font name="System Bold" size="22.0"/></font>
                </Label>
                <Label fx:id="priceLabel" style="-fx-font-size: 18px; -fx-text-fill: #2e7d32; -fx-font-weight: bold;"/>
                <Label fx:id="categoryCityLabel" style="-fx-text-fill: gray;"/>
                <Label fx:id="statusValueLabel" style="-fx-font-weight: bold;"/>
                <Label fx:id="rejectionReasonLabel" style="-fx-text-fill: #c62828;" wrapText="true"/>

                <Separator/>

                <Label text="Description" style="-fx-font-weight: bold;"/>
                <Label fx:id="descriptionLabel" wrapText="true"/>

                <Separator/>

                <Label text="Seller" style="-fx-font-weight: bold;"/>
                <Label fx:id="sellerLabel"/>
                <Label fx:id="sellerRatingLabel"/>

                <Label fx:id="ownerNoteLabel" style="-fx-text-fill: gray;" wrapText="true"/>

                <HBox spacing="10">
                    <Button fx:id="favoriteButton" onAction="#handleToggleFavorite" text="Add to Favorites"/>
                    <Button fx:id="messageButton" onAction="#handleMessageSeller" text="Message Seller"/>
                    <Button fx:id="rateButton" onAction="#handleRateSeller" text="Rate Seller"/>
                </HBox>

                <Label fx:id="statusLabel" style="-fx-text-fill: red;" wrapText="true"/>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
