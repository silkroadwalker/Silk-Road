<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.silkroad.ui.AdDetailsController"
            prefWidth="1000" prefHeight="680" styleClass="page-body">

    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="top-bar">
            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
            <Button text="&lt; Back" onAction="#goBack" styleClass="back-button"/>
            <Label text="Ad Details" styleClass="page-title"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="ads-grid-scroll">
            <VBox spacing="14" maxWidth="760">
                <padding><Insets top="16" right="16" bottom="24" left="16"/></padding>

                <HBox fx:id="imagesBox" spacing="8"/>

                <VBox spacing="8" styleClass="detail-card">
                    <Label fx:id="titleLabel" wrapText="true" styleClass="detail-title"/>
                    <Label fx:id="priceLabel" styleClass="price-label"/>
                    <Label fx:id="categoryCityLabel" styleClass="muted-label"/>
                    <Label fx:id="statusValueLabel" styleClass="muted-label"/>
                    <Label fx:id="rejectionReasonLabel" styleClass="error-label" wrapText="true"/>
                </VBox>

                <VBox spacing="8" styleClass="detail-card">
                    <Label text="Description" styleClass="section-title"/>
                    <Label fx:id="descriptionLabel" wrapText="true"/>
                </VBox>

                <VBox spacing="8" styleClass="detail-card">
                    <Label text="Seller" styleClass="section-title"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label fx:id="sellerLabel"/>
                    </HBox>
                    <Label fx:id="sellerRatingLabel" styleClass="muted-label"/>
                    <Label fx:id="ownerNoteLabel" styleClass="muted-label" wrapText="true"/>
                </VBox>

                <HBox spacing="10">
                    <Button fx:id="favoriteButton" onAction="#handleToggleFavorite" text="Add to Favorites"/>
                    <Button fx:id="messageButton" onAction="#handleMessageSeller" text="Message Seller" styleClass="primary-button"/>
                    <Button fx:id="rateButton" onAction="#handleRateSeller" text="Rate Seller"/>
                </HBox>

                <HBox fx:id="ownerActionsBox" spacing="10" visible="false" managed="false">
                    <Button fx:id="editButton" onAction="#handleEditAd" text="Edit" styleClass="primary-button"/>
                    <Button fx:id="markSoldButton" onAction="#handleMarkSoldAd" text="Mark as Sold"/>
                    <Button fx:id="deleteButton" onAction="#handleDeleteAd" text="Delete" styleClass="danger-button"/>
                </HBox>

                <Label fx:id="statusLabel" styleClass="status-label" wrapText="true"/>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>