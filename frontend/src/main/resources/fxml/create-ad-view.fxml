<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="CONTROLLER_NAME">
   <children>
      <Label fx:id="headerLabel" alignment="CENTER" layoutX="231.0" layoutY="27.0" prefHeight="52.0" prefWidth="141.0" text="Create New Ad">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <Button layoutX="25.0" layoutY="26.0" mnemonicParsing="false" onAction="#goBack" text="Back" />
      <TextField fx:id="titleField" layoutX="74.0" layoutY="79.0" prefHeight="27.0" prefWidth="455.0" promptText="Title" />
      <TextField fx:id="descriptionField" alignment="TOP_LEFT" layoutX="73.0" layoutY="114.0" prefHeight="100.0" prefWidth="455.0" promptText="Description" />
      <TextField fx:id="priceField" layoutX="73.0" layoutY="225.0" prefHeight="27.0" prefWidth="455.0" promptText="Price" />
      <TextField fx:id="cityField" layoutX="74.0" layoutY="268.0" prefHeight="27.0" prefWidth="455.0" promptText="City" />
      <TextField fx:id="categoryField" layoutX="74.0" layoutY="306.0" prefHeight="27.0" prefWidth="455.0" promptText="Category" />
      <Button fx:id="submitButton" layoutX="209.0" layoutY="359.0" mnemonicParsing="false" onAction="#handleSubmit" prefHeight="27.0" prefWidth="182.0" text="Submit" />
   </children>
</AnchorPane>
