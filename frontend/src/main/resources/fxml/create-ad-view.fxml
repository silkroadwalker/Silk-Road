<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="560.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.silkroad.ui.CreateAdController">
   <children>
      <Label fx:id="headerLabel" alignment="CENTER" layoutX="231.0" layoutY="27.0" prefHeight="52.0" prefWidth="141.0" text="Create New Ad">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <Button layoutX="25.0" layoutY="26.0" mnemonicParsing="false" onAction="#goBack" text="Back" />
      <TextField fx:id="titleField" layoutX="74.0" layoutY="79.0" prefHeight="27.0" prefWidth="455.0" promptText="Title" />
      <TextArea fx:id="descriptionField" layoutX="74.0" layoutY="112.0" prefHeight="106.0" prefRowCount="4" prefWidth="455.0" promptText="Description" wrapText="true" />
      <TextField fx:id="priceField" layoutX="73.0" layoutY="225.0" prefHeight="27.0" prefWidth="455.0" promptText="Price" />
      <ComboBox fx:id="cityComboBox" layoutX="74.0" layoutY="268.0" prefHeight="27.0" prefWidth="455.0" promptText="City" />
      <ComboBox fx:id="categoryComboBox" layoutX="74.0" layoutY="306.0" prefHeight="27.0" prefWidth="455.0" promptText="Category" />

      <Button layoutX="74.0" layoutY="344.0" mnemonicParsing="false" onAction="#handleChooseImages" text="Choose Images..." />
      <ListView fx:id="imagesListView" layoutX="74.0" layoutY="378.0" prefHeight="80.0" prefWidth="455.0" />

      <Label fx:id="statusLabel" layoutX="74.0" layoutY="466.0" prefWidth="455.0" style="-fx-text-fill: red;" wrapText="true" />

      <Button fx:id="submitButton" layoutX="209.0" layoutY="500.0" mnemonicParsing="false" onAction="#handleSubmit" prefHeight="27.0" prefWidth="182.0" text="Submit" />
   </children>
</AnchorPane>