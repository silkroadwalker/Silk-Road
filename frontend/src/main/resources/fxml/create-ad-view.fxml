<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.silkroad.ui.CreateAdController"
            prefWidth="1000" prefHeight="680" styleClass="page-body">

   <top>
      <HBox spacing="10" alignment="CENTER_LEFT" styleClass="top-bar">
         <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
         <Button text="&lt; Back" onAction="#goBack" styleClass="back-button"/>
         <Label fx:id="headerLabel" text="Create New Ad" styleClass="page-title"/>
      </HBox>
   </top>

   <center>
      <ScrollPane fitToWidth="true" styleClass="ads-grid-scroll">
         <StackPane>
            <VBox spacing="14" maxWidth="560" styleClass="detail-card">
               <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
               <StackPane.margin>
                  <Insets top="24" left="20" right="20" bottom="24"/>
               </StackPane.margin>

               <VBox spacing="6">
                  <Label text="Title" styleClass="field-label"/>
                  <TextField fx:id="titleField" promptText="e.g. Mountain bike, barely used"/>
               </VBox>

               <VBox spacing="6">
                  <Label text="Description" styleClass="field-label"/>
                  <TextArea fx:id="descriptionField" prefRowCount="4" wrapText="true" promptText="Describe condition, size, extras..."/>
               </VBox>

               <VBox spacing="6">
                  <Label text="Price" styleClass="field-label"/>
                  <TextField fx:id="priceField" promptText="0.00"/>
               </VBox>

               <HBox spacing="14">
                  <VBox spacing="6" HBox.hgrow="ALWAYS">
                     <Label text="City" styleClass="field-label"/>
                     <ComboBox fx:id="cityComboBox" promptText="City" maxWidth="Infinity"/>
                  </VBox>
                  <VBox spacing="6" HBox.hgrow="ALWAYS">
                     <Label text="Category" styleClass="field-label"/>
                     <ComboBox fx:id="categoryComboBox" promptText="Category" maxWidth="Infinity"/>
                     <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Subcategory" styleClass="field-label"/>
                        <ComboBox fx:id="subCategoryComboBox" promptText="Subcategory" maxWidth="Infinity" disable="true"/>
                     </VBox>
                  </VBox>
               </HBox>

               <VBox spacing="6">
                  <Label text="Photos" styleClass="field-label"/>
                  <Button onAction="#handleChooseImages" text="Choose Images..."/>
                  <ListView fx:id="imagesListView" prefHeight="90"/>
               </VBox>

               <Label fx:id="statusLabel" styleClass="status-label" wrapText="true"/>

               <Button fx:id="submitButton" onAction="#handleSubmit" text="Submit" styleClass="primary-button" maxWidth="Infinity"/>
            </VBox>
         </StackPane>
      </ScrollPane>
   </center>

</BorderPane>
