<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.silkroad.ui.AdminController" prefWidth="800" prefHeight="600">
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Button text="Back" onAction="#goBack"/>
            <Label text="Admin Panel" styleClass="page-title"/>
        </HBox>
    </top>
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">

            <Tab text="Pending Ads">
                <BorderPane>
                    <center>
                        <ListView fx:id="pendingListView" BorderPane.alignment="CENTER"/>
                    </center>
                    <bottom>
                        <VBox spacing="8">
                            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                            <Label text="Rejection reason (required to reject):"/>
                            <TextArea fx:id="reasonField" prefRowCount="2" wrapText="true"/>
                            <HBox spacing="10">
                                <Button text="Approve" onAction="#handleApprove" styleClass="primary-button"/>
                                <Button text="Reject" onAction="#handleReject" styleClass="danger-button"/>
                                <Button text="Refresh" onAction="#handleRefreshPending"/>
                            </HBox>
                            <Label fx:id="statusLabel"/>
                        </VBox>
                    </bottom>
                </BorderPane>
            </Tab>

            <Tab text="Categories">
                <BorderPane>
                    <center>
                        <ListView fx:id="categoriesListView" BorderPane.alignment="CENTER"/>
                    </center>
                    <bottom>
                        <VBox spacing="8">
                            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                            <TextField fx:id="categoryNameField" promptText="Category name"/>
                            <HBox spacing="10">
                                <Button text="Add" onAction="#handleAddCategory" styleClass="primary-button"/>
                                <Button text="Rename Selected" onAction="#handleRenameCategory"/>
                                <Button text="Delete Selected" onAction="#handleDeleteCategory" styleClass="danger-button"/>
                            </HBox>
                            <Label fx:id="categoryStatusLabel"/>
                        </VBox>
                    </bottom>
                </BorderPane>
            </Tab>

            <Tab text="Users">
                <BorderPane>
                    <center>
                        <ListView fx:id="usersListView" BorderPane.alignment="CENTER"/>
                    </center>
                    <bottom>
                        <VBox spacing="8">
                            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                            <HBox spacing="10">
                                <Button text="Block" onAction="#handleBlockUser" styleClass="danger-button"/>
                                <Button text="Unblock" onAction="#handleUnblockUser" styleClass="primary-button"/>
                                <Button text="Refresh" onAction="#handleRefreshUsers"/>
                            </HBox>
                            <Label fx:id="usersStatusLabel"/>
                        </VBox>
                    </bottom>
                </BorderPane>
            </Tab>

        </TabPane>
    </center>
</BorderPane>