<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.silkroad.ui.AdminController"
            prefWidth="1100" prefHeight="700" styleClass="page-body, admin-dash">
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="top-bar">
            <padding>
                <Insets top="12" right="16" bottom="12" left="16"/>
            </padding>
            <Button text="&lt; Back" onAction="#goBack" styleClass="back-button"/>
            <Label text="Admin Panel" styleClass="page-title"/>
        </HBox>
    </top>
    <center>
        <HBox>

            <!-- ============ SIDEBAR NAV ============ -->
            <VBox styleClass="sidebar" prefWidth="220" minWidth="220" spacing="4">
                <padding><Insets top="20" right="12" bottom="20" left="12"/></padding>

                <Button fx:id="navDashboardBtn" text="Dashboard" onAction="#showDashboard"
                        styleClass="nav-item, nav-item-active" maxWidth="Infinity"/>
                <Button fx:id="navPendingBtn" text="Pending Ads" onAction="#showPending"
                        styleClass="nav-item" maxWidth="Infinity"/>
                <Button fx:id="navAllAdsBtn" text="All Ads" onAction="#showAllAds"
                        styleClass="nav-item" maxWidth="Infinity"/>
                <Button fx:id="navCategoriesBtn" text="Categories" onAction="#showCategories"
                        styleClass="nav-item" maxWidth="Infinity"/>
                <Button fx:id="navUsersBtn" text="Users" onAction="#showUsers"
                        styleClass="nav-item" maxWidth="Infinity"/>
            </VBox>

            <!-- ============ CONTENT PANES ============ -->
            <StackPane HBox.hgrow="ALWAYS">

                <!-- Dashboard -->
                <BorderPane fx:id="dashboardPane" styleClass="page-body" visible="true" managed="true">
                    <center>
                        <ScrollPane fitToWidth="true" BorderPane.alignment="CENTER" styleClass="ads-grid-scroll">
                            <VBox spacing="18">
                                <padding><Insets top="20" right="24" bottom="24" left="24"/></padding>

                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <Label text="Overview" styleClass="section-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button text="Refresh" onAction="#handleRefreshDashboard"/>
                                </HBox>

                                <HBox spacing="16">
                                    <VBox styleClass="stat-card" spacing="14" HBox.hgrow="ALWAYS">
                                        <HBox alignment="CENTER_LEFT" spacing="8">
                                            <Label text="&#128101;" styleClass="stat-icon, stat-icon-green"/>
                                            <Label text="TOTAL USERS" styleClass="stat-card-label"/>
                                        </HBox>
                                        <Label fx:id="totalUsersLabel" styleClass="detail-title"/>
                                    </VBox>

                                    <VBox styleClass="stat-card" spacing="14" HBox.hgrow="ALWAYS">
                                        <HBox alignment="CENTER_LEFT" spacing="8">
                                            <Label text="&#8987;" styleClass="stat-icon, stat-icon-orange"/>
                                            <Label text="PENDING ADS" styleClass="stat-card-label"/>
                                        </HBox>
                                        <Label fx:id="pendingAdsCountLabel" styleClass="detail-title"/>
                                    </VBox>

                                    <VBox styleClass="stat-card" spacing="14" HBox.hgrow="ALWAYS">
                                        <HBox alignment="CENTER_LEFT" spacing="8">
                                            <Label text="&#9989;" styleClass="stat-icon, stat-icon-teal"/>
                                            <Label text="ACTIVE ADS" styleClass="stat-card-label"/>
                                        </HBox>
                                        <Label fx:id="activeAdsCountLabel" styleClass="detail-title"/>
                                    </VBox>
                                </HBox>

                                <HBox spacing="16">
                                    <VBox styleClass="chart-card" spacing="12" HBox.hgrow="ALWAYS">
                                        <Label text="Ads Overview" styleClass="section-title"/>
                                        <BarChart fx:id="dashboardChart" styleClass="dashboard-chart" legendVisible="false"
                                                  animated="false" categoryGap="60" barGap="4"
                                                  prefHeight="320" VBox.vgrow="ALWAYS">
                                            <xAxis>
                                                <CategoryAxis label="Metric" side="BOTTOM"/>
                                            </xAxis>
                                            <yAxis>
                                                <NumberAxis label="Count" side="LEFT"/>
                                            </yAxis>
                                        </BarChart>
                                    </VBox>

                                    <VBox styleClass="side-card" spacing="12" prefWidth="260" minWidth="240">
                                        <Label text="Insights" styleClass="section-title"/>
                                        <Label fx:id="dashboardNoteLabel" styleClass="empty-state" wrapText="true"/>
                                    </VBox>
                                </HBox>

                            </VBox>
                        </ScrollPane>
                    </center>
                </BorderPane>

                <!-- Pending Ads -->
                <BorderPane fx:id="pendingPane" styleClass="page-body" visible="false" managed="false">
                    <top>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <padding><Insets top="12" right="12" bottom="0" left="12"/></padding>
                            <Button text="Refresh" onAction="#handleRefreshPending"/>
                        </HBox>
                    </top>
                    <center>
                        <ScrollPane fitToWidth="true" BorderPane.alignment="CENTER" styleClass="ads-grid-scroll">
                            <VBox>
                                <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                                <FlowPane fx:id="pendingFlowPane" hgap="16" vgap="16"/>
                            </VBox>
                        </ScrollPane>
                    </center>
                    <bottom>
                        <Label fx:id="statusLabel" styleClass="empty-state" wrapText="true">
                            <padding><Insets top="0" right="12" bottom="12" left="12"/></padding>
                        </Label>
                    </bottom>
                </BorderPane>

                <!-- All Ads -->
                <BorderPane fx:id="allAdsPane" styleClass="page-body" visible="false" managed="false">
                    <top>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <padding><Insets top="12" right="12" bottom="0" left="12"/></padding>
                            <TextField fx:id="allAdsSearchField" promptText="Search by title or seller" HBox.hgrow="ALWAYS"/>
                            <Button text="Search" onAction="#handleAllAdsSearch" styleClass="primary-button"/>
                        </HBox>
                    </top>
                    <center>
                        <ScrollPane fitToWidth="true" BorderPane.alignment="CENTER" styleClass="ads-grid-scroll">
                            <VBox>
                                <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                                <FlowPane fx:id="allAdsFlowPane" hgap="16" vgap="16"/>
                            </VBox>
                        </ScrollPane>
                    </center>
                    <bottom>
                        <VBox spacing="8">
                            <padding><Insets top="10" right="12" bottom="12" left="12"/></padding>
                            <Button text="Refresh" onAction="#handleRefreshAllAds"/>
                            <Label fx:id="allAdsStatusLabel" styleClass="empty-state" wrapText="true"/>
                        </VBox>
                    </bottom>
                </BorderPane>

                <!-- Categories -->
                <BorderPane fx:id="categoriesPane" styleClass="page-body" visible="false" managed="false">
                    <center>
                        <ListView fx:id="categoriesListView" BorderPane.alignment="CENTER">
                            <BorderPane.margin><Insets top="12" right="12" bottom="0" left="12"/></BorderPane.margin>
                        </ListView>
                    </center>
                    <bottom>
                        <VBox spacing="8">
                            <padding><Insets top="10" right="12" bottom="12" left="12"/></padding>
                            <TextField fx:id="categoryNameField" promptText="Category name"/>
                            <HBox spacing="10">
                                <Button text="Add" onAction="#handleAddCategory" styleClass="primary-button"/>
                                <Button text="Rename Selected" onAction="#handleRenameCategory"/>
                                <Button text="Delete Selected" onAction="#handleDeleteCategory" styleClass="danger-button"/>
                            </HBox>
                            <Label fx:id="categoryStatusLabel" styleClass="empty-state"/>
                        </VBox>
                    </bottom>
                </BorderPane>

                <!-- Users -->
                <BorderPane fx:id="usersPane" styleClass="page-body" visible="false" managed="false">
                    <center>
                        <ListView fx:id="usersListView" BorderPane.alignment="CENTER">
                            <BorderPane.margin><Insets top="12" right="12" bottom="0" left="12"/></BorderPane.margin>
                        </ListView>
                    </center>
                    <bottom>
                        <VBox spacing="8">
                            <padding><Insets top="10" right="12" bottom="12" left="12"/></padding>
                            <HBox spacing="10">
                                <Button text="Block" onAction="#handleBlockUser" styleClass="danger-button"/>
                                <Button text="Unblock" onAction="#handleUnblockUser" styleClass="primary-button"/>
                                <Button text="Refresh" onAction="#handleRefreshUsers"/>
                            </HBox>
                            <Label fx:id="usersStatusLabel" styleClass="empty-state" wrapText="true"/>
                        </VBox>
                    </bottom>
                </BorderPane>

            </StackPane>
        </HBox>
    </center>
</BorderPane>
