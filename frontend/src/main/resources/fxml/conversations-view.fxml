<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.silkroad.ui.ConversationsController"
            prefWidth="1000" prefHeight="680" styleClass="page-body">
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="top-bar">
            <padding>
                <Insets top="12" right="16" bottom="12" left="16"/>
            </padding>
            <Button text="&lt; Back" onAction="#goBack" styleClass="back-button"/>
            <Label text="Messages" styleClass="page-title"/>
            <Pane HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" styleClass="ads-grid-scroll">
            <VBox fx:id="conversationsBox" spacing="10">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            </VBox>
        </ScrollPane>
    </center>
    <bottom>
        <Label fx:id="statusLabel" styleClass="empty-state" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets top="0" right="16" bottom="12" left="16"/>
            </BorderPane.margin>
        </Label>
    </bottom>
</BorderPane>
