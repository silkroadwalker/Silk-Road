<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.silkroad.ui.HomeController"
            prefWidth="1000" prefHeight="680" styleClass="page-body, home-page">

    <top>
        <VBox styleClass="top-bar, home-top-bar">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <padding><Insets top="12" right="16" bottom="8" left="16"/></padding>
                <Label fx:id="welcomeLabel" text="Welcome!" styleClass="page-title, home-title"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="Create Ad" onAction="#goToCreateAd" styleClass="primary-button, home-create-button"/>
                <Button text="My Ads" onAction="#goToMyAds" styleClass="nav-pill, nav-pill-mint"/>
                <Button text="Favorites" onAction="#goToFavorites" styleClass="nav-pill, nav-pill-coral"/>
                <Button text="Messages" onAction="#goToMessages" styleClass="nav-pill, nav-pill-sky"/>
                <Button fx:id="adminButton" text="Admin" onAction="#goToAdmin" visible="false" managed="false"
                        styleClass="nav-pill, nav-pill-gold"/>
                <Button text="Logout" onAction="#handleLogout" styleClass="nav-pill, nav-pill-muted"/>
            </HBox>

            <HBox spacing="8" alignment="CENTER_LEFT" styleClass="home-filter-bar">
                <padding><Insets top="0" right="16" bottom="12" left="16"/></padding>
                <TextField fx:id="searchField" promptText="Search ads..." HBox.hgrow="ALWAYS"/>
                <MenuButton fx:id="categoryMenuButton" text="Category" prefWidth="160" styleClass="category-menu-button"/>
                <ComboBox fx:id="cityFilterBox" promptText="City" prefWidth="130"/>
                <TextField fx:id="minPriceField" promptText="Min price" prefWidth="80"/>
                <TextField fx:id="maxPriceField" promptText="Max price" prefWidth="80"/>
                <ComboBox fx:id="sortBox" promptText="Sort by" prefWidth="140"/>
                <Button text="Search" onAction="#handleSearch" styleClass="primary-button"/>
                <Button text="Clear" onAction="#handleClearFilters"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="ads-grid-scroll">
            <VBox>
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                <FlowPane fx:id="adsFlowPane" hgap="16" vgap="16"/>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <Label fx:id="statusLabel" styleClass="empty-state">
            <padding><Insets top="0" right="16" bottom="12" left="16"/></padding>
        </Label>
    </bottom>

</BorderPane>
