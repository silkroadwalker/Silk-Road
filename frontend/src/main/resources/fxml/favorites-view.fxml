<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>

<BorderPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.silkroad.ui.FavoritesController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10">
            <padding><Insets bottom="10" left="10" right="10" top="10" /></padding>
            <Button onAction="#goBack" text="&lt; Back" />
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Favorites" />
            <Pane HBox.hgrow="ALWAYS" />
            <Button fx:id="removeButton" onAction="#handleRemoveFavorite" text="Remove" />
        </HBox>
    </top>
    <center>
        <ListView fx:id="favoritesListView" />
    </center>
    <bottom>
        <Label fx:id="statusLabel" style="-fx-text-fill: red;">
            <padding><Insets bottom="5" left="10" right="10" top="5" /></padding>
        </Label>
    </bottom>
</BorderPane>
