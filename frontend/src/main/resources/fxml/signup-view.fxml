<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.silkroad.ui.SignupController"
           prefWidth="1000" prefHeight="680" styleClass="page-body">

    <VBox alignment="CENTER" maxWidth="360" maxHeight="-Infinity" spacing="12" styleClass="auth-card">
        <padding><Insets top="32" right="36" bottom="32" left="36"/></padding>

        <Label text="Create Account" styleClass="page-title"/>
        <Label text="Join Silk-Road to start buying and selling" styleClass="auth-subtitle" wrapText="true" alignment="CENTER"/>

        <TextField fx:id="fullNameField" promptText="Full Name" maxWidth="280"/>
        <TextField fx:id="usernameField" promptText="Username" maxWidth="280"/>
        <TextField fx:id="emailField" promptText="Email" maxWidth="280"/>
        <TextField fx:id="phoneField" promptText="Phone" maxWidth="280"/>
        <PasswordField fx:id="passwordField" promptText="Password" maxWidth="280"/>

        <Label fx:id="errorLabel" styleClass="status-label" visible="false" wrapText="true" maxWidth="280"/>

        <Button fx:id="signupButton" text="Sign Up" onAction="#handleSignup" maxWidth="280" styleClass="primary-button"/>
        <Hyperlink onAction="#goToLogin" text="Already have an account? Log in"/>
    </VBox>

</StackPane>
